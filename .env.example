# ============================================
# DentyMD - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR_STRONG_PASSWORD@localhost:5432/denty-app?schema=public

# Node environment (development | production)
NODE_ENV=development

# Public site URL (used for sitemap, canonical URLs, OG tags)
NEXT_PUBLIC_SITE_URL=https://dentymd.md

# Docker Compose overrides (used by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
POSTGRES_DB=denty-app

# Session secret — REQUIRED (minimum 32 random characters)
# Generate with: openssl rand -hex 32
SESSION_SECRET=GENERATE_A_STRONG_SECRET_HERE

# Vercel Blob (for file uploads, optional - only if using Vercel Blob storage)
# BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Sentry error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Telegram webhook security (optional, but recommended in production)
# TELEGRAM_WEBHOOK_SECRET=GENERATE_A_RANDOM_SECRET_HERE

# Seed admin password (only used during prisma db seed)
# SEED_ADMIN_PASSWORD=parola-admin-seed
