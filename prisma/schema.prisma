generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  email           String
  phone           String
  description     String
  radiographyLink String?
  country         String
  budget          String?
  status          String     @default("NOU")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  auditLogs       AuditLog[]
  offers          Offer[]
  patient         Patient?

  @@index([status])
  @@index([country])
  @@index([createdAt])
  @@index([email])
}

model Admin {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String
  role             String         @default("MANAGER")
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  name             String?
  lastSeen         DateTime?
  clinicId         String?
  language         String         @default("ro")
  clinic           Clinic?        @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  auditLogs        AuditLog[]
  receivedMessages Message[]      @relation("ReceivedMessages")
  messages         Message[]      @relation("SentMessages")
  notifications    Notification[]
  reactions        Reaction[]

  @@index([clinicId])
  @@index([role])
  @@index([active])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("INFO")
  link      String?
  createdAt DateTime @default(now())
  user      Admin    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model Message {
  id          String       @id @default(cuid())
  content     String
  senderId    String
  createdAt   DateTime     @default(now())
  receiverId  String?
  attachments Attachment[]
  receiver    Admin?       @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender      Admin        @relation("SentMessages", fields: [senderId], references: [id])
  reactions   Reaction[]

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int?
  messageId String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  messageId String
  userId    String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      Admin    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Content {
  key       String
  locale    String   @default("ro")
  value     String
  updatedAt DateTime @updatedAt

  @@id([key, locale])
}

model Translation {
  key       String
  locale    String
  value     String
  updatedAt DateTime @updatedAt

  @@id([key, locale])
}

model Language {
  code      String   @id
  name      String
  flag      String   @default("🏳️")
  active    Boolean  @default(true)
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())
  adminId   String?
  leadId    String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([leadId])
}

model Hotel {
  id            String    @id @default(cuid())
  name          String
  location      String
  stars         Int       @default(3)
  pricePerNight Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  patients      Patient[]
}

model Clinic {
  id        String    @id @default(cuid())
  name      String
  location  String
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  admins    Admin[]
  patients  Patient[]
}

model Patient {
  id          String    @id @default(cuid())
  name        String
  treatment   String
  hotelId     String?
  arrivalDate DateTime?
  status      String    @default("IN_ASTEPTARE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  leadId      String?   @unique
  clinicId    String?
  invoices    Invoice[]
  offers      Offer[]
  clinic      Clinic?   @relation(fields: [clinicId], references: [id])
  hotel       Hotel?    @relation(fields: [hotelId], references: [id])
  lead        Lead?     @relation(fields: [leadId], references: [id])
  radiographyLink String?

  @@index([clinicId])
  @@index([status])
  @@index([createdAt])
}

model Service {
  id           String        @id @default(cuid())
  name         String
  price        Decimal       @db.Decimal(10, 2)
  currency     String        @default("EUR")
  category     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  invoiceItems InvoiceItem[]
  offerItems   OfferItem[]
}

model Offer {
  id         String      @id @default(cuid())
  number     String      @unique
  date       DateTime    @default(now())
  validUntil DateTime
  status     String      @default("DRAFT")
  total      Decimal     @db.Decimal(10, 2)
  currency   String      @default("EUR")
  notes      String?
  patientId  String?
  leadId     String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  invoice    Invoice?
  lead       Lead?       @relation(fields: [leadId], references: [id])
  patient    Patient?    @relation(fields: [patientId], references: [id])
  items      OfferItem[]
}

model OfferItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  serviceId   String?
  offerId     String
  offer       Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  service     Service? @relation(fields: [serviceId], references: [id])
}

model Invoice {
  id         String           @id @default(cuid())
  series     String           @default("INV")
  number     String
  date       DateTime         @default(now())
  dueDate    DateTime
  status     String           @default("DRAFT")
  total      Decimal          @db.Decimal(10, 2)
  paidAmount Decimal          @default(0) @db.Decimal(10, 2)
  currency   String           @default("EUR")
  notes      String?
  patientId  String?
  offerId    String?          @unique
  settingsId String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  offer      Offer?           @relation(fields: [offerId], references: [id])
  patient    Patient?         @relation(fields: [patientId], references: [id])
  settings   InvoiceSettings? @relation(fields: [settingsId], references: [id])
  items      InvoiceItem[]

  @@unique([series, number])
  @@index([status])
  @@index([createdAt])
  @@index([patientId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  serviceId   String?
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service     Service? @relation(fields: [serviceId], references: [id])
}

model Post {
  id          String   @id @default(cuid())
  title       String
  content     String?
  type        String
  mediaUrl    String?
  mediaType   String?
  beforeImage String?
  afterImage  String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvoiceSettings {
  id             String    @id @default(cuid())
  name           String    @default("Română")
  language       String    @default("ro")
  companyName    String    @default("CLINICA TA")
  companyAddress String    @default("Str. Exemplului nr. 1, București, Sector 1")
  companyCif     String    @default("RO123456")
  companyRegCom  String    @default("J40/123/2024")
  companyEmail   String    @default("contact@clinica.ro")
  bankName       String    @default("Banca Transilvania")
  bankIban       String    @default("RO00 BTRL 0000 0000 0000 00XX")
  footerText     String    @default("Această factură circulă fără semnătură și ștampilă conform legii.")
  logoUrl        String?
  tvaRate        Decimal   @default(0) @db.Decimal(5, 2)
  updatedAt      DateTime  @updatedAt
  invoices       Invoice[]

  @@unique([language])
}

model TelegramSettings {
  id         String          @id @default(cuid())
  botToken   String
  webhookUrl String          @default("")
  isActive   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  users      TelegramUser[]
}

model TelegramUser {
  id             String           @id @default(cuid())
  telegramUserId String
  label          String           @default("")
  isActive       Boolean          @default(true)
  settingsId     String
  settings       TelegramSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@unique([telegramUserId, settingsId])
}

model SecurityScript {
  id        String   @id @default(cuid())
  name      String
  type      String   // "css" or "js"
  content   String   @db.Text
  isActive  Boolean  @default(true)
  position  String   @default("head") // "head" or "body"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CaptchaSettings {
  id        String   @id @default(cuid())
  provider  String   @default("cloudflare")
  siteKey   String   @default("")
  secretKey String   @default("")
  isEnabled Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model SentrySettings {
  id        String   @id @default(cuid())
  dsn       String   @default("")
  authToken String   @default("")
  isEnabled Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model SecurityLog {
  id        String   @id @default(cuid())
  level     String   // "info", "warning", "error", "critical"
  event     String
  message   String
  details   String?  @db.Text
  ipAddress String?
  userAgent String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([event])
  @@index([createdAt])
}
